# ============================================================================
# Neo-App Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the required values for local development

# ============================================================================
# DATABASE
# ============================================================================
# MySQL/TiDB connection string
DATABASE_URL=mysql://user:password@localhost:3306/neo_app

# ============================================================================
# AUTHENTICATION & OAUTH
# ============================================================================
# Manus OAuth configuration (auto-injected in production)
JWT_SECRET=your-jwt-secret-key-here-min-32-chars
VITE_APP_ID=your-manus-app-id
OAUTH_SERVER_URL=https://api.manus.im
VITE_OAUTH_PORTAL_URL=https://portal.manus.im
OWNER_OPEN_ID=your-owner-open-id
OWNER_NAME=Your Name

# ============================================================================
# MANUS BUILT-IN SERVICES
# ============================================================================
# Manus Forge API for LLM, Image Generation, Storage, etc.
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=your-forge-api-key
VITE_FRONTEND_FORGE_API_URL=https://forge.manus.im
VITE_FRONTEND_FORGE_API_KEY=your-frontend-forge-api-key

# ============================================================================
# LLM CONFIGURATION
# ============================================================================
# OpenAI API Key for script analysis
# Models available: gpt-4.1-mini, gpt-4.1-nano, gemini-2.5-flash
OPENAI_API_KEY=your-openai-api-key
OPENAI_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini

# ============================================================================
# IMAGE GENERATION
# ============================================================================
# Manus Image Service for generating scene images
# Uses the BUILT_IN_FORGE_API_KEY for authentication
IMAGE_SERVICE_TIMEOUT=30000

# ============================================================================
# STORAGE (S3)
# ============================================================================
# AWS S3 configuration for storing character images and generated scenes
# Uses Manus S3 proxy (credentials auto-injected in production)
S3_BUCKET=neo-app-storage
S3_REGION=us-east-1
S3_ENDPOINT=https://s3.amazonaws.com

# ============================================================================
# ANALYTICS
# ============================================================================
# Manus Analytics for tracking user behavior
VITE_ANALYTICS_ENDPOINT=https://analytics.manus.im
VITE_ANALYTICS_WEBSITE_ID=your-website-id

# ============================================================================
# APPLICATION
# ============================================================================
# Application title and logo (displayed in UI and dashboard)
VITE_APP_TITLE=Neo-App
VITE_APP_LOGO=https://cdn.example.com/logo.png

# ============================================================================
# DEVELOPMENT
# ============================================================================
# Environment mode
NODE_ENV=development

# Enable debug logging
DEBUG=neo-app:*

# Frontend dev server port
VITE_PORT=5173

# Backend server port
SERVER_PORT=3000
